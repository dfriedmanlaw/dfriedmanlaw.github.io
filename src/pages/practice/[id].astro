---
import Layout from '@/src/layouts/Layout.astro';
import PracticePage from '@/pages/PracticePage';
import { PRACTICE_AREAS } from '@/constants';

export function getStaticPaths() {
  return PRACTICE_AREAS.map((area) => ({
    params: { id: area.id },
    props: { area },
  }));
}

const { area } = Astro.props;
const title = `${area.title} | Law Office of David Friedman`;
const description = area.description;

const breadcrumb = [
  { name: area.title, item: `https://davidfriedmanlaw.com/practice/${area.id}/` }
];
---

<Layout title={title} description={description} breadcrumb={breadcrumb}>
	<PracticePage id={area.id} />
</Layout>
